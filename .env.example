# Camera Sync — environment variables (copy to .env or export before running)
# Required
CAMERA_SYNC_BUCKET=your-bucket-name

# Optional — defaults shown
CAMERA_SYNC_BASE_DIR=/var/ftp/local
CAMERA_SYNC_PREFIX=cam
CAMERA_SYNC_LOG_DIR=/var/log/camera
CAMERA_SYNC_PROJECT=camera-sync
CAMERA_SYNC_MIN_AGE_SEC=120
CAMERA_SYNC_MAX_RETRIES=3
CAMERA_SYNC_TIMEOUT_SEC=480
# CAMERA_SYNC_MAX_PROCESS_WORKERS=
# CAMERA_SYNC_MAX_THREAD_WORKERS=
CAMERA_SYNC_FAILURE_LOG=/var/log/camera/upload_failures.jsonl
